<Window x:Class="MyShop.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyShop.Client"
        xmlns:vm="clr-namespace:MyShop.Client.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:ProductViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#2D2D30" VerticalAlignment="Stretch">
            <TextBlock Text="Menu" Foreground="White" FontWeight="Bold" FontSize="18" Margin="16,24,0,24" />
            <Button Content="Dashboard" Margin="8,4" Height="40" />
            <Button Content="Products" Margin="8,4" Height="40" />
            <Button Content="Orders" Margin="8,4" Height="40" />
            <Button Content="Reports" Margin="8,4" Height="40" />
            <Button Content="Settings" Margin="8,4" Height="40" />
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="White">
            <TextBlock Text="Main Content Area" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" Foreground="#444" />
        </Grid>
    </Grid>
</Window>
